{
    "name": "urb-strategy-factory-ui",
    "version": "1.0.0",
    "description": "Professional UI for URB Strategy Factory",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "concurrently \"cross-env BROWSER=none npm run react-start\" \"wait-on http://127.0.0.1:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron .\"",
        "react-start": "react-scripts start",
        "build": "react-scripts build"
    },
    "author": "Shakti Ayala",
    "license": "ISC",
    "devDependencies": {
        "concurrently": "^8.0.0",
        "cross-env": "^7.0.0",
        "electron": "^28.3.3",
        "wait-on": "^7.0.0"
    },
    "dependencies": {
        "axios": "^1.6.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-scripts": "5.0.1",
        "recharts": "^2.10.0"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    }
}
